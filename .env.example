# Stripe
# Copia estas variables en Render > Environment.
STRIPE_SECRET_KEY=sk_test_tu_secret_key_aqui

# Pago unico para renta de espacios.
# El precio lo manda el frontend en cada pago como "amount" en centavos.
# El servidor agrega automaticamente una comision de servicio del 10%.
# Ejemplo: 150000 = $1,500.00 MXN.
STRIPE_CURRENCY=mxn

# URL de tu frontend. Usala para limitar quien puede llamar al servidor.
# Si tienes mas de un origen permitido, separalos con comas.
CORS_ORIGIN=https://espacio-en-red.onrender.com
FRONTEND_URL=https://espacio-en-red.onrender.com

# Cambia estas URLs por las rutas reales de tu app.
CHECKOUT_SUCCESS_URL=https://espacio-en-red.onrender.com/pago-exitoso
CHECKOUT_CANCEL_URL=https://espacio-en-red.onrender.com/pago-cancelado
