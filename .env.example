# Stripe
# Copia estas variables en Render > Environment.
STRIPE_SECRET_KEY=sk_test_tu_secret_key_aqui

# Pago unico para renta de espacios.
# Stripe usa centavos: 1000 = $10.00 MXN, 150000 = $1,500.00 MXN.
STRIPE_CURRENCY=mxn
SPACE_RENTAL_AMOUNT=150000

# Cambia estas URLs por las rutas reales de tu app en Render.
CHECKOUT_SUCCESS_URL=https://tu-app.onrender.com/pago-exitoso
CHECKOUT_CANCEL_URL=https://tu-app.onrender.com/pago-cancelado
